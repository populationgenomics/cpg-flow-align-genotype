<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>VNtyper Reports</title>
    <meta name="description" content="VNtyper Report Index">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg:          #0f1117;
        --surface:     #1a1d27;
        --surface-alt: #21253a;
        --border:      #2e3350;
        --accent:      #6366f1;
        --accent-glow: rgba(99,102,241,0.25);
        --text:        #e2e8f0;
        --text-muted:  #7c85a2;
        --green:       #22c55e;
        --green-bg:    rgba(34,197,94,0.12);
        --amber:       #f59e0b;
        --amber-bg:    rgba(245,158,11,0.12);
        --red:         #ef4444;
        --red-bg:      rgba(239,68,68,0.12);
        --blue:        #38bdf8;
        --blue-bg:     rgba(56,189,248,0.12);
      }

      body {
        font-family: 'Inter', system-ui, sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        font-size: 14px;
        line-height: 1.6;
      }

      /* ── Header ── */
      header {
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        padding: 0 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        height: 60px;
        position: sticky;
        top: 0;
        z-index: 100;
        backdrop-filter: blur(10px);
      }

      .logo-pill {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--accent-glow);
        border: 1px solid var(--accent);
        border-radius: 8px;
        padding: 4px 12px;
        font-weight: 700;
        font-size: 13px;
        color: #a5b4fc;
        letter-spacing: 0.05em;
      }

      .logo-pill svg {
        width: 16px;
        height: 16px;
      }

      header h1 {
        font-size: 16px;
        font-weight: 600;
        color: var(--text);
      }

      header .subtitle {
        font-size: 12px;
        color: var(--text-muted);
        margin-left: auto;
      }

      /* ── Main layout ── */
      main {
        max-width: 1100px;
        margin: 0 auto;
        padding: 2.5rem 2rem;
      }

      .page-header {
        margin-bottom: 2rem;
      }

      .page-header h2 {
        font-size: 22px;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 4px;
      }

      .page-header p {
        color: var(--text-muted);
        font-size: 13px;
      }

      /* ── Controls ── */
      .controls {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.25rem;
      }

      .search-wrap {
        position: relative;
        flex: 1;
        max-width: 360px;
      }

      .search-wrap svg {
        position: absolute;
        left: 10px;
        top: 50%;
        transform: translateY(-50%);
        width: 15px;
        height: 15px;
        color: var(--text-muted);
        pointer-events: none;
      }

      #search {
        width: 100%;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text);
        font-family: inherit;
        font-size: 13px;
        padding: 8px 12px 8px 34px;
        outline: none;
        transition: border-color .15s;
      }

      #search::placeholder { color: var(--text-muted); }
      #search:focus { border-color: var(--accent); }

      .count-badge {
        margin-left: auto;
        font-size: 12px;
        color: var(--text-muted);
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 3px 12px;
      }

      /* ── Table card ── */
      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      thead {
        background: var(--surface-alt);
        border-bottom: 1px solid var(--border);
      }

      th {
        padding: 11px 16px;
        text-align: left;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-muted);
        cursor: pointer;
        user-select: none;
        white-space: nowrap;
      }

      th:hover { color: var(--text); }

      th .sort-icon {
        display: inline-block;
        margin-left: 4px;
        opacity: 0.4;
        font-size: 10px;
        vertical-align: middle;
      }

      th.sort-asc .sort-icon::after  { content: " ▲"; opacity: 1; }
      th.sort-desc .sort-icon::after { content: " ▼"; opacity: 1; }
      th:not(.sort-asc):not(.sort-desc) .sort-icon::after { content: " ⇅"; }

      tbody tr {
        border-bottom: 1px solid var(--border);
        transition: background .1s;
      }

      tbody tr:last-child { border-bottom: none; }
      tbody tr:hover { background: var(--surface-alt); }

      td {
        padding: 12px 16px;
        vertical-align: middle;
      }

      /* participant cell */
      .participant-cell {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }

      .participant-link {
        color: #a5b4fc;
        text-decoration: none;
        font-weight: 500;
        font-size: 13px;
        transition: color .15s;
      }

      .participant-link:hover { color: #c4b5fd; text-decoration: underline; }

      .sgid {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        color: var(--text-muted);
      }

      /* result badges */
      .badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        border-radius: 6px;
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.04em;
        white-space: nowrap;
      }

      .badge-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        flex-shrink: 0;
      }

      .badge-positive {
        background: var(--red-bg);
        color: var(--red);
        border: 1px solid rgba(239,68,68,0.3);
      }
      .badge-positive .badge-dot { background: var(--red); }

      .badge-negative {
        background: var(--green-bg);
        color: var(--green);
        border: 1px solid rgba(34,197,94,0.3);
      }
      .badge-negative .badge-dot { background: var(--green); }

      .badge-unknown {
        background: rgba(124,133,162,0.1);
        color: var(--text-muted);
        border: 1px solid var(--border);
      }
      .badge-unknown .badge-dot { background: var(--text-muted); }

      /* date cell */
      .date-cell {
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        color: var(--text-muted);
      }

      /* ── Empty state ── */
      .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--text-muted);
      }

      .empty-state svg {
        width: 48px;
        height: 48px;
        margin-bottom: 1rem;
        opacity: 0.4;
      }

      /* ── Footer ── */
      footer {
        text-align: center;
        padding: 2rem;
        font-size: 12px;
        color: var(--text-muted);
        border-top: 1px solid var(--border);
        margin-top: 3rem;
      }
    </style>
  </head>

  <body>
    <header>
      <div class="logo-pill">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/>
        </svg>
        VNtyper
      </div>
      <h1>{{ title }}</h1>
      <span class="subtitle">Variable Number Tandem Repeat Analysis</span>
    </header>

    <main>
      <div class="page-header">
        <h2>Report Index</h2>
        <p>VNTR genotyping results from AdVNTR and Kestrel callers</p>
      </div>

      <div class="controls">
        <div class="search-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input id="search" type="text" placeholder="Search participant or SGID…">
        </div>
        <span class="count-badge" id="row-count"></span>
      </div>

      <div class="card">
        <table id="report-table">
          <thead>
            <tr>
              <th data-col="0">Participant<span class="sort-icon"></span></th>
              <th data-col="1">AdVNTR<span class="sort-icon"></span></th>
              <th data-col="2">Kestrel<span class="sort-icon"></span></th>
              <th data-col="3" class="sort-desc">Date<span class="sort-icon"></span></th>
            </tr>
          </thead>
          <tbody id="table-body">
            {% for sgid, report in reports.items() %}
            <tr>
              <td>
                <div class="participant-cell">
                  <a class="participant-link" href="{{ report.url }}" target="_blank" rel="noopener">
                    {{ report.participant }}
                  </a>
                  <span class="sgid">{{ sgid }}</span>
                </div>
              </td>
              <td data-result>{{ report.advntr }}</td>
              <td data-result>{{ report.kestrel }}</td>
              <td class="date-cell">{{ report.timestamp }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
        <div class="empty-state" id="empty-state" style="display:none">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <p>No results match your search.</p>
        </div>
      </div>
    </main>

    <footer>
      Generated by cpg-flow-align-genotype &middot; VNtyper pipeline
    </footer>

    <script>
      // ── Badge renderer (fallback if Jinja filter not available) ──
      // The result_badge filter should render <span class="badge badge-*">…</span>.
      // This JS handles raw text values if the filter outputs them as-is.
      function classifyResult(text) {
        if (!text) return 'badge-unknown';
        const t = text.toString().toLowerCase().trim();
        if (/positive|detected|pathogenic|expanded/.test(t)) return 'badge-positive';
        if (/negative|not.detected|normal|unaffected/.test(t)) return 'badge-negative';
        return 'badge-unknown';
      }

      // Convert plain-text result cells to styled badges
      document.querySelectorAll('#table-body td[data-result]').forEach(td => {
        const raw = td.textContent.trim();
        const cls = classifyResult(raw);
        td.innerHTML = `<span class="badge ${cls}"><span class="badge-dot"></span>${raw || '—'}</span>`;
      });

      // ── Search ──
      const search = document.getElementById('search');
      const rows = Array.from(document.querySelectorAll('#table-body tr'));
      const countEl = document.getElementById('row-count');
      const emptyEl = document.getElementById('empty-state');

      function updateCount(n) {
        countEl.textContent = `${n} of ${rows.length} participant${rows.length !== 1 ? 's' : ''}`;
      }

      search.addEventListener('input', () => {
        const q = search.value.toLowerCase();
        let visible = 0;
        rows.forEach(row => {
          const match = row.textContent.toLowerCase().includes(q);
          row.style.display = match ? '' : 'none';
          if (match) visible++;
        });
        emptyEl.style.display = visible === 0 ? 'block' : 'none';
        updateCount(visible);
      });

      updateCount(rows.length);

      // ── Column sort ──
      let sortCol = 3, sortDir = -1;

      document.querySelectorAll('th[data-col]').forEach(th => {
        th.addEventListener('click', () => {
          const col = parseInt(th.dataset.col);
          if (sortCol === col) {
            sortDir *= -1;
          } else {
            sortCol = col;
            sortDir = 1;
          }
          document.querySelectorAll('th').forEach(t => t.classList.remove('sort-asc', 'sort-desc'));
          th.classList.add(sortDir === 1 ? 'sort-asc' : 'sort-desc');
          sortTable(col, sortDir);
        });
      });

      function sortTable(col, dir) {
        const tbody = document.getElementById('table-body');
        const sorted = rows.slice().sort((a, b) => {
          const av = a.cells[col]?.textContent.trim() ?? '';
          const bv = b.cells[col]?.textContent.trim() ?? '';
          return av.localeCompare(bv, undefined, {numeric: true}) * dir;
        });
        sorted.forEach(r => tbody.appendChild(r));
      }

      // Initial sort by date descending
      document.querySelector('th[data-col="3"]').click();
      document.querySelector('th[data-col="3"]').click();
    </script>
  </body>
</html>
